<launch>
  <arg name="odom_topic_name" default="odom" />

  <!--
    Phase 1 bridge only.
    The base driver remains owned by the platform workspace on the deployed
    machine. The local reference copy is analysis-only.

    Upstream scout_minimal.launch fixes port_name and simulated_robot with
    value=..., so this wrapper must not try to override them.
  -->
  <include file="$(find scout_bringup)/launch/scout_minimal.launch">
    <arg name="odom_topic_name" value="$(arg odom_topic_name)" />
  </include>
</launch>
